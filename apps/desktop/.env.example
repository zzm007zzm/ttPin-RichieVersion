# Desktop (Vite) env vars
# Create a file named `.env.local` in this same folder for your own values.
#
# Translator - AI Foundry translate endpoint (preview)
# Example:
# https://<your-resource>.services.ai.azure.com/translator/text/translate
VITE_AZURE_TRANSLATOR_TRANSLATE_ENDPOINT=

# Subscription key + region
VITE_AZURE_TRANSLATOR_KEY=
VITE_AZURE_TRANSLATOR_REGION=

# Target model deployment name from languages API "models" list (e.g. gpt-4o)
VITE_AZURE_TRANSLATOR_DEPLOYMENT_NAME=gpt-4o

# Optional override (normally no key needed)
# Default: https://api.cognitive.microsofttranslator.com/languages
VITE_AZURE_TRANSLATOR_LANGUAGES_ENDPOINT=
