# ===== Backend =====
# Postgres connection string
DATABASE_URL=postgresql://ttpin:ttpin@localhost:5432/ttpin

# JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Admin
ADMIN_EMAIL=admin@example.com

# Azure Translator (Mode 1 - developer-provided quota)
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
AZURE_TRANSLATOR_REGION=your-region
AZURE_TRANSLATOR_KEY=your-key
# Azure Translator LLM deployment name (Azure AI Foundry deployment)
AZURE_TRANSLATOR_DEPLOYMENT_NAME=general

# Azure Communication Services Email (for email verification)
ACS_EMAIL_CONNECTION_STRING=your-acs-connection-string
ACS_EMAIL_FROM=no-reply@your-verified-domain

# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173
